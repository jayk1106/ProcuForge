# ProcuForge Cloud Run deployment configuration
#
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Fill in your values (especially API_CORS_ORIGINS after Vercel deploy)
# 3. Run one-time setup:  ./scripts/setup_cloud_run_once.sh
# 4. Deploy / update:      ./scripts/deploy_cloud_run.sh
#
# .env.production is gitignored — never commit this file.
# JWT_SECRET and ADMIN_PASSWORD_HASH are injected into Cloud Run on each deploy.

# =============================================================================
# Deploy tooling (used by scripts — NOT sent to the Cloud Run container)
# =============================================================================

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

CLOUD_RUN_SERVICE=procuforge-api
ARTIFACT_REGISTRY_REPO=procuforge
IMAGE_NAME=api
IMAGE_TAG=latest

# Cloud Run runtime service account (created by setup_cloud_run_once.sh)
SERVICE_ACCOUNT=procuforge-run@your-gcp-project-id.iam.gserviceaccount.com

# Container / scaling
CLOUD_RUN_PORT=8080
CLOUD_RUN_TIMEOUT=3600
CLOUD_RUN_MIN_INSTANCES=1
CLOUD_RUN_MAX_INSTANCES=3
CLOUD_RUN_CPU=2
CLOUD_RUN_MEMORY=2Gi
CLOUD_RUN_SESSION_AFFINITY=true
CLOUD_RUN_ALLOW_UNAUTHENTICATED=true

# When true, deploy script reads reasoning engine IDs from logs/*_deployment_metadata.json
SYNC_REASONING_ENGINES_FROM_LOGS=true

# Optional: run curl health checks after deploy
VERIFY_AFTER_DEPLOY=true

# =============================================================================
# Cloud Run runtime env (injected into the container on every deploy)
# =============================================================================

API_ENV=production

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Auth — same env var names as api/config.py (generate with scripts/generate_auth_secrets.py)
JWT_SECRET='paste-from-generate_auth_secrets.py'
ADMIN_PASSWORD_HASH='paste-from-generate_auth_secrets.py'

# From logs/procu-forge-buyer_deployment_metadata.json (or set SYNC_REASONING_ENGINES_FROM_LOGS=true)
BUYER_REASONING_ENGINE=projects/PROJECT_NUMBER/locations/us-central1/reasoningEngines/BUYER_ENGINE_ID

# From logs/procu-forge-vendor_deployment_metadata.json
VENDOR_REASONING_ENGINE=projects/PROJECT_NUMBER/locations/us-central1/reasoningEngines/VENDOR_ENGINE_ID

# Internal vendor A2A (loopback inside the container — do not change unless you refactor)
VENDOR_A2A_AGENT_CARD_URL=http://127.0.0.1:8001/.well-known/agent-card.json
VENDOR_SERVER_HOST=127.0.0.1
VENDOR_SERVER_PORT=8001

WORKFLOW_DEFAULT_USER_ID=your-user-uuid
WORKFLOW_DEFAULT_ORGANIZATION_ID=your-org-uuid

# Exact frontend origin(s), comma-separated, no spaces — set after Vercel deploy
API_CORS_ORIGINS=https://your-app.vercel.app

# Admin profile (optional — defaults exist in api/config.py)
ADMIN_USER_ID=your-user-uuid
ADMIN_ORG_ID=your-org-uuid
# ADMIN_USER_NAME=
# ADMIN_USER_EMAIL=
# ADMIN_USER_ROLE=Procurement Manager
# ADMIN_ORG_NAME=
# ADMIN_ORG_CURRENCY=USD
