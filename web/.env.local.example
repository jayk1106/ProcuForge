# Local development — frontend calls the FastAPI server directly.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (Vercel) — set in the Vercel project dashboard, not here:
# NEXT_PUBLIC_API_URL=https://procuforge-api-xxxxx-uc.a.run.app
#
# The session cookie lives on the Cloud Run API domain. Auth is enforced
# client-side via AuthGate + GET /auth/me (see docs/production_setup_guide.md).
