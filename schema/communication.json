{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Procurement Agent Communication Schema",
  "description": "Message schemas for A2A communication in the procurement workflow per docs/buyer_vendor_communication_reference.md. Validate every inbound message against `envelope` first, then dispatch on `message_type` to the matching `messages.<TYPE>.payload_schema`.",

  "envelope": {
    "type": "object",
    "required": [
      "message_id",
      "rfq_id",
      "vendor_id",
      "from_agent",
      "to_agent",
      "message_type",
      "timestamp",
      "payload"
    ],
    "properties": {
      "message_id": {
        "type": "string",
        "description": "Unique ID for this message. Used for idempotency and deduplication.",
        "examples": ["msg_rfq_001"]
      },
      "rfq_id": {
        "type": "string",
        "description": "Correlation ID that threads the entire transaction from RFQ to PROCESS_COMPLETE.",
        "examples": ["rfq_2026_0001"]
      },
      "vendor_id": {
        "type": "string",
        "description": "Identifies which vendor's pricing/context the vendor agent should load.",
        "examples": ["vendor_123"]
      },
      "buyer_org_id": {
        "type": "string",
        "description": "Optional. Identifies the buyer's organization so the vendor can look up vendorOrgRelations for relationship-aware pricing (average discount, relationship strength, preferred-vendor status). Missing or empty -> vendor treats buyer as new and uses defaults.",
        "examples": ["org_acme"]
      },
      "from_agent": {
        "type": "string",
        "enum": ["buyer_agent", "vendor_agent"]
      },
      "to_agent": {
        "type": "string",
        "enum": ["buyer_agent", "vendor_agent"]
      },
      "message_type": {
        "type": "string",
        "enum": [
          "RFQ",
          "QUOTE",
          "COUNTER_OFFER",
          "ACCEPT",
          "WALKAWAY",
          "RFQ_CLOSED",
          "PO",
          "PO_ACKNOWLEDGED",
          "GRN_CREATED",
          "INVOICE_SUBMITTED",
          "PROCESS_COMPLETE"
        ]
      },
      "round": {
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 3,
        "description": "Negotiation round number: 0 = RFQ/QUOTE, 1-3 = negotiation rounds, null for post-negotiation messages."
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when the message was created."
      },
      "payload": {
        "type": "object",
        "description": "Message-type-specific content. See `messages` section for schema per type."
      }
    }
  },

  "$defs": {
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code.",
      "enum": ["USD", "EUR", "GBP", "INR", "JPY", "CNY", "AUD", "CAD"]
    },
    "walkaway_reason": {
      "type": "string",
      "enum": ["PRICE_GAP_TOO_LARGE", "MAX_ROUNDS_REACHED", "VENDOR_REJECTED", "BUYER_CANCELLED", "QUOTE_EXPIRED"]
    },
    "rfq_close_reason": {
      "type": "string",
      "enum": ["ANOTHER_VENDOR_SELECTED", "RFQ_CANCELLED", "NO_SUITABLE_VENDOR"]
    },
    "rfq_close_outcome": {
      "type": "string",
      "enum": ["NOT_SELECTED", "CANCELLED"]
    },
    "item": {
      "type": "object",
      "required": ["product_id", "sku", "quantity", "unit"],
      "properties": {
        "product_id": { "type": "string" },
        "sku": { "type": "string" },
        "quantity": { "type": "integer", "minimum": 1 },
        "unit": { "type": "string", "examples": ["pcs"] }
      }
    }
  },

  "messages": {
    "RFQ": {
      "direction": "buyer_agent -> vendor_agent",
      "phase": "negotiation",
      "description": "Initial request for quote. Starts the transaction.",
      "payload_schema": {
        "type": "object",
        "required": ["item", "required_by", "response_deadline"],
        "properties": {
          "item": { "$ref": "#/$defs/item" },
          "required_by": { "type": "string", "format": "date" },
          "response_deadline": { "type": "string", "format": "date-time" }
        }
      }
    },

    "QUOTE": {
      "direction": "vendor_agent -> buyer_agent",
      "phase": "negotiation",
      "description": "Vendor's initial price quote in response to RFQ.",
      "payload_schema": {
        "type": "object",
        "required": ["item", "unit_price", "total_price", "currency", "required_by", "response_deadline"],
        "properties": {
          "item": { "$ref": "#/$defs/item" },
          "unit_price": { "type": "number", "minimum": 0 },
          "total_price": { "type": "number", "minimum": 0 },
          "currency": { "$ref": "#/$defs/currency" },
          "required_by": { "type": "string", "format": "date" },
          "response_deadline": { "type": "string", "format": "date-time" }
        }
      }
    },

    "COUNTER_OFFER": {
      "direction": "buyer_agent <-> vendor_agent (either side)",
      "phase": "negotiation",
      "description": "Counter offer in either direction. `is_final = true` marks a best-and-final offer.",
      "payload_schema": {
        "type": "object",
        "required": ["item", "unit_price", "total_price", "currency", "is_final", "required_by", "response_deadline"],
        "properties": {
          "item": { "$ref": "#/$defs/item" },
          "unit_price": { "type": "number", "minimum": 0 },
          "total_price": { "type": "number", "minimum": 0 },
          "currency": { "$ref": "#/$defs/currency" },
          "is_final": { "type": "boolean" },
          "required_by": { "type": "string", "format": "date" },
          "response_deadline": { "type": "string", "format": "date-time" }
        }
      }
    },

    "ACCEPT": {
      "direction": "buyer_agent <-> vendor_agent (either side)",
      "phase": "negotiation",
      "description": "Accept the latest price. Locks the agreed terms for downstream PO generation.",
      "payload_schema": {
        "type": "object",
        "required": ["item", "unit_price", "total_price", "currency", "required_by", "response_deadline"],
        "properties": {
          "item": { "$ref": "#/$defs/item" },
          "unit_price": { "type": "number", "minimum": 0 },
          "total_price": { "type": "number", "minimum": 0 },
          "currency": { "$ref": "#/$defs/currency" },
          "required_by": { "type": "string", "format": "date" },
          "response_deadline": { "type": "string", "format": "date-time" }
        }
      }
    },

    "WALKAWAY": {
      "direction": "buyer_agent <-> vendor_agent (either side)",
      "phase": "negotiation",
      "description": "Negotiation ends with no deal.",
      "payload_schema": {
        "type": "object",
        "required": ["item", "reason"],
        "properties": {
          "item": { "$ref": "#/$defs/item" },
          "reason": { "$ref": "#/$defs/walkaway_reason" },
          "last_unit_price": { "type": "number", "minimum": 0 },
          "last_total_price": { "type": "number", "minimum": 0 },
          "required_by": { "type": "string", "format": "date" },
          "response_deadline": { "type": "string", "format": "date-time" }
        }
      }
    },

    "RFQ_CLOSED": {
      "direction": "buyer_agent -> vendor_agent",
      "phase": "vendor_selection",
      "description": "Notifies a vendor that the RFQ thread is closed (e.g. another vendor was selected).",
      "payload_schema": {
        "type": "object",
        "required": ["item", "outcome", "reason"],
        "properties": {
          "item": { "$ref": "#/$defs/item" },
          "outcome": { "$ref": "#/$defs/rfq_close_outcome" },
          "reason": { "$ref": "#/$defs/rfq_close_reason" }
        }
      }
    },

    "PO": {
      "direction": "buyer_agent -> vendor_agent",
      "phase": "po",
      "description": "Formal purchase order issued to the selected vendor.",
      "payload_schema": {
        "type": "object",
        "required": ["po_number", "rfq_reference", "line_items", "total_amount", "currency", "delivery_date"],
        "properties": {
          "po_number": { "type": "string" },
          "rfq_reference": { "type": "string" },
          "line_items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["sku", "product_id", "quantity", "unit_price", "total_price"],
              "properties": {
                "sku": { "type": "string" },
                "product_id": { "type": "string" },
                "quantity": { "type": "integer", "minimum": 1 },
                "unit_price": { "type": "number", "minimum": 0 },
                "total_price": { "type": "number", "minimum": 0 }
              }
            }
          },
          "total_amount": { "type": "number", "minimum": 0 },
          "currency": { "$ref": "#/$defs/currency" },
          "delivery_date": { "type": "string", "format": "date" }
        }
      }
    },

    "PO_ACKNOWLEDGED": {
      "direction": "vendor_agent -> buyer_agent",
      "phase": "po",
      "description": "Vendor confirms receipt of the PO. Slim acknowledgement carrying only the po_number.",
      "payload_schema": {
        "type": "object",
        "required": ["po_number"],
        "properties": {
          "po_number": { "type": "string" }
        }
      }
    },

    "GRN_CREATED": {
      "direction": "buyer_agent -> vendor_agent",
      "phase": "grn",
      "description": "Goods receipt note. Records received quantities per line item.",
      "payload_schema": {
        "type": "object",
        "required": ["grn_number", "po_number", "received_at", "line_items"],
        "properties": {
          "grn_number": { "type": "string" },
          "po_number": { "type": "string" },
          "received_at": { "type": "string", "format": "date-time" },
          "line_items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["sku", "unit_quantity"],
              "properties": {
                "sku": { "type": "string" },
                "unit_quantity": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },

    "INVOICE_SUBMITTED": {
      "direction": "vendor_agent -> buyer_agent",
      "phase": "invoice",
      "description": "Vendor submits invoice for the delivered goods.",
      "payload_schema": {
        "type": "object",
        "required": ["invoice_number", "po_number", "invoice_date", "line_items", "total_amount", "currency"],
        "properties": {
          "invoice_number": { "type": "string" },
          "po_number": { "type": "string" },
          "grn_reference": { "type": "string" },
          "invoice_date": { "type": "string", "format": "date" },
          "line_items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["sku", "quantity", "unit_price", "total_price"],
              "properties": {
                "sku": { "type": "string" },
                "quantity": { "type": "integer", "minimum": 1 },
                "unit_price": { "type": "number", "minimum": 0 },
                "total_price": { "type": "number", "minimum": 0 }
              }
            }
          },
          "total_amount": { "type": "number", "minimum": 0 },
          "currency": { "$ref": "#/$defs/currency" },
          "due_date": { "type": "string", "format": "date" }
        }
      }
    },

    "PROCESS_COMPLETE": {
      "direction": "buyer_agent -> vendor_agent",
      "phase": "completion",
      "description": "Lifecycle terminator. Carries the trio of identifiers stitching PO, GRN, and invoice together.",
      "payload_schema": {
        "type": "object",
        "required": ["po_number", "grn_number", "invoice_number"],
        "properties": {
          "po_number": { "type": "string" },
          "grn_number": { "type": "string" },
          "invoice_number": { "type": "string" }
        }
      }
    }
  }
}
